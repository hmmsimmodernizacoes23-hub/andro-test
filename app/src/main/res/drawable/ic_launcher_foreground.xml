<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Glowing accent or sound waves in the background (Safe 66dp zone: 21 to 87) -->
    <!-- Sound Waves bars -->
    <path
        android:fillColor="#FF8A80"
        android:pathData="M24,44 L28,44 L28,64 L24,64 Z" />
    <path
        android:fillColor="#80DEEA"
        android:pathData="M31,36 L35,36 L35,72 L31,72 Z" />
    <path
        android:fillColor="#FF8A80"
        android:pathData="M73,36 L77,36 L77,72 L73,72 Z" />
    <path
        android:fillColor="#80DEEA"
        android:pathData="M80,44 L84,44 L84,64 L80,64 Z" />

    <!-- Left Note Head (Tilt ellipse shape in safe zone) -->
    <path
        android:pathData="M38,64 C32,64 27,67.5 27,72 C27,76.5 32,80 38,80 C44,80 49,76.5 49,72 C49,67.5 44,64 38,64 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="27"
                android:startY="64"
                android:endX="49"
                android:endY="80"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF007F" />
                <item android:offset="1.0" android:color="#00E5FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right Note Head -->
    <path
        android:pathData="M59,54 C53,54 48,57.5 48,62 C48,66.5 53,70 59,70 C65,70 70,66.5 70,62 C70,57.5 65,54 59,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="48"
                android:startY="54"
                android:endX="70"
                android:endY="70"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF007F" />
                <item android:offset="1.0" android:color="#00E5FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Stems -->
    <!-- Left vertical stem -->
    <path
        android:pathData="M44,38 L48,36 L48,72 L44,72 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="44"
                android:startY="36"
                android:endX="48"
                android:endY="72"
                android:type="linear">
                <item android:offset="0.0" android:color="#D0BCFE" />
                <item android:offset="1.0" android:color="#00E5FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right vertical stem -->
    <path
        android:pathData="M65,28 L69,26 L69,62 L65,62 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="65"
                android:startY="26"
                android:endX="69"
                android:endY="62"
                android:type="linear">
                <item android:offset="0.0" android:color="#D0BCFE" />
                <item android:offset="1.0" android:color="#00E5FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Double note connecting beam (slanted top) -->
    <path
        android:pathData="M44,34 L69,24 L69,32 L44,42 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="44"
                android:startY="24"
                android:endX="69"
                android:endY="42"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF007F" />
                <item android:offset="1.0" android:color="#00E5FF" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
